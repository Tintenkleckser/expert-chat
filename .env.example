PORT=8787
# Local development only. On Vercel this can stay empty so the app calls /api.
VITE_API_BASE=http://127.0.0.1:8787
# Optional for static hosting with Supabase Edge Functions.
VITE_CHAT_STREAM_URL=https://your-project.supabase.co/functions/v1/expert-chat-stream
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_MATCH_DIK2_FUNCTION=match_wissen_dik2
SUPABASE_MATCH_HANDBUCH_FUNCTION=match_wissen_handbuch

# mistral or openai
LLM_PROVIDER=mistral

MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_CHAT_MODEL=mistral-large-latest
MISTRAL_EMBEDDING_MODEL=mistral-embed

OPENAI_API_KEY=your-openai-api-key
OPENAI_CHAT_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
